# ============================================================
# Auto OLT — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Django Core ─────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-server-ip

# ── Database ─────────────────────────────────────────────────
# SQLite (dev only):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (production recommended):
# DATABASE_URL=postgres://user:password@localhost:5432/auto_olt

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Encryption (OLT passwords at rest) ───────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Never change this after data is written — existing passwords become unreadable.
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ── HMAC Response Signing ────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must match NEXT_PUBLIC_HMAC_SECRET in frontend .env
HMAC_SECRET=your-hmac-secret-here

# ── Admin ────────────────────────────────────────────────────
# Change to a secret path — never leave as 'admin/'
ADMIN_URL=your-secret-admin-path/

# ── Registration ─────────────────────────────────────────────
REGISTRATION_OPEN=True

# ── OTP ──────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Site URL (used in email links) ───────────────────────────
SITE_URL=https://yourdomain.com

# ── HTTPS Security (set True when behind SSL) ────────────────
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=WARNING

# ── Email / SMTP ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Auto OLT <your-email@gmail.com>

# ── ONU Provisioning ─────────────────────────────────────────
ONU_REGISTER_METHOD=hybrid
DEFAULT_TELNET_USERNAME=admin
DEFAULT_TELNET_PASSWORD=admin
DEFAULT_TELNET_PORT=23
OLT_MGMT_USER=autoolt
OLT_MGMT_PASSWORD=your-mgmt-password
OLT_MGMT_PRIVILEGE=15

# ── WireGuard ────────────────────────────────────────────────
WG_INTERFACE=wg0
WG_ENDPOINT=your-server-public-ip:51820
WG_SERVER_PUBLIC_KEY=your-wireguard-server-public-key
