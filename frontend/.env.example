# ============================================================
# Auto OLT — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── API ──────────────────────────────────────────────────────
# Backend Django API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ── HMAC Response Verification ───────────────────────────────
# Must match HMAC_SECRET in backend .env exactly
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
NEXT_PUBLIC_HMAC_SECRET=your-hmac-secret-here
